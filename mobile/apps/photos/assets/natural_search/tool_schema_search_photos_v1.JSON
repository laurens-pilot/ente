{
  "type": "function",
  "function": {
    "name": "search_photos_v1",
    "description": "Plan a natural-language Ente Photos search using simple structured fields.",
    "parameters": {
      "type": "object",
      "properties": {
        "time_query": {
          "type": "string",
          "description": "Raw time phrase from the user, such as last month, March 2024, or August 14 till August 20 of 2024."
        },
        "album_names": {
          "type": "array",
          "description": "Exact saved album names from runtime context.",
          "items": {
            "type": "string"
          }
        },
        "media_type": {
          "type": "string",
          "description": "Requested media type.",
          "enum": [
            "photo",
            "video",
            "both"
          ]
        },
        "ownership_scope": {
          "type": "string",
          "description": "Ownership or sharing scope.",
          "enum": [
            "mine",
            "shared_with_me",
            "shared_by_contacts",
            "all_accessible"
          ]
        },
        "shared_by_contacts": {
          "type": "array",
          "description": "Exact contact names from runtime context for who shared the media.",
          "items": {
            "type": "string"
          }
        },
        "people_in_media": {
          "type": "array",
          "description": "Exact person names from runtime context.",
          "items": {
            "type": "string"
          }
        },
        "people_mode": {
          "type": "string",
          "description": "How to combine multiple named people.",
          "enum": [
            "any",
            "all"
          ]
        },
        "place_names": {
          "type": "array",
          "description": "Saved location tag names from runtime context or free-text places.",
          "items": {
            "type": "string"
          }
        },
        "visual_query": {
          "type": "string",
          "description": "Visible content query."
        },
        "text_query": {
          "type": "string",
          "description": "Caption, description, or filename text."
        },
        "camera_query": {
          "type": "string",
          "description": "Camera make or model query."
        },
        "file_format": {
          "type": "string",
          "description": "File format or extension, such as jpg, heic, mp4, or mov."
        },
        "video_duration_seconds": {
          "type": "object",
          "description": "Video duration range.",
          "properties": {
            "min": {
              "type": "integer"
            },
            "max": {
              "type": "integer"
            }
          }
        },
        "file_size_mb": {
          "type": "object",
          "description": "File size range in MB.",
          "properties": {
            "min": {
              "type": "integer"
            },
            "max": {
              "type": "integer"
            }
          }
        },
        "limit": {
          "type": "integer",
          "description": "Maximum result count."
        }
      }
    }
  }
}
